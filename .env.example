## 文章輪巡跟單 Bot 設定（範例）

# Telegram Bot Token（必填）
TELEGRAM_BOT_TOKEN=

# Telegram 代理（可選；若伺服器無法直連 api.telegram.org 時設定，如 socks5://host:port 或 http://user:pass@host:port；SOCKS 需 pip install aiohttp-socks）
TELEGRAM_PROXY=

# 公開頻道 chat_id（必填，例如 -1001234567890；Bot 需是頻道管理員）
PUBLIC_CHANNEL_ID=

# 後端 /posts/list 完整 URL（必填）
POSTS_URL=https://api.example.com/posts/list

# 後端請求 headers（可選，JSON 字串）
# 例：{"Authorization":"Bearer xxx","Content-Type":"application/json"}
POSTS_HEADERS_JSON=

# 帶單信號詳情（必填）：/bot/follow_orders/view?id=xxx
FOLLOW_ORDER_VIEW_URL=http://127.0.0.1:5003/bot/follow_orders/view

# 帶單信號詳情 headers（可選，JSON 字串；不填則沿用 POSTS_HEADERS_JSON）
FOLLOW_ORDER_HEADERS_JSON=

# 輪巡間隔（秒，預設 15）
POLL_INTERVAL_SECONDS=15

# 信號互動有效期（秒，預設 86400=1天；超過後按鈕/流程將無法繼續）
SIGNAL_TTL_SECONDS=86400

# 綁定/驗證（可選；設 REQUIRE_BINDING=1 則必須綁定後才能跟單/下單）
REQUIRE_BINDING=0
# 綁定狀態查詢 API（例：GET /bot/bind/status?tg_user_id=xxx）
BIND_STATUS_URL=
# 綁定狀態查詢 headers（可選，JSON 字串）
BIND_HEADERS_JSON=
# 綁定查詢參數：type / brand（對應 query params）
BIND_THIRD_TYPE=telegram
BIND_BRAND=BYD

# 平台 API（餘額/下單/撤單/查委託等共用同一個 base，路徑不同）
PLATFORM_API_BASE_URL=
PLATFORM_API_HEADERS_JSON=
PLATFORM_WALLET=W001
PLATFORM_BRAND=BYD
PLATFORM_CANCEL_ORDER_PATH=/trade/batch_cancel_orders
EXCHANGE_INFO_REFRESH_SECONDS=3600

# 當 API 沒有回 verify_url 時，改用模板生成驗證 URL（可選）
# 例：https://bydfi.example.com/verify?tg_user_id={tg_user_id}
BIND_VERIFY_URL_TEMPLATE=
# 綁定狀態快取秒數（預設 300；0 表示不快取）
BIND_CACHE_SECONDS=300

# DB 連線（可選；不填會預設 sqlite）
# sqlite:
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# mysql（如需）：mysql+aiomysql://user:pass@localhost:3306/dbname
# DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/bot_db

